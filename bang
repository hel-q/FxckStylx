local au = nil

Mode.MouseButton1Click:Connect(function()
    if wfc then return end
    if pnamemode then
        -- currently By Name -> switch to Find Player
        if au then au:Pause(); au:Destroy(); au = nil end
        -- tween out (move Username off-screen) then hide
        Username.Visible = true
        au = ts:Create(Username, hstinfo2, huTweenProps)
        Mode.Text = "Mode: Find Player"
        au:Play()
        pnamemode = not pnamemode
        au.Completed:Wait()
        Username.Visible = false
    else
        -- currently Find Player -> switch to By Name
        if au then au:Pause(); au:Destroy(); au = nil end
        Username.Visible = true
        au = ts:Create(Username, hstinfo2, suTweenProps)
        Mode.Text = "Mode: By Name"
        au:Play()
        pnamemode = not pnamemode
    end
end)

-- Touch variable holder
local touched = nil

-- Start/Stop behavior (StopPlay button)
StopPlay.MouseButton1Click:Connect(function()
    if not target and wfc ~= true then
        if pnamemode then
            -- Target by name mode
            local foundTarget = false
            for _,plr in pairs(game.Players:GetPlayers()) do
                if plr ~= lplr and plr.Character then
                    -- Check both Name and DisplayName (prefix)
                    local search = Username.Text or ""
                    if search ~= "" and (string.match(plr.Name,"^"..search) or (plr.DisplayName ~= "" and string.match(plr.DisplayName,"^"..search))) then
                        target = plr.Character
                        if lplr.Character and lplr.Character:FindFirstChild("Humanoid") then
                            lplr.Character:FindFirstChild("Humanoid").PlatformStand = true
                        end
                        StopPlay.Text = "Stop"
                        foundTarget = true
                        break
                    end
                end
            end
            if not foundTarget then
                -- Flash red if target not found
                StopPlay.BackgroundColor3 = Color3.fromRGB(104,0,0)
                task.wait(0.5)
                StopPlay.BackgroundColor3 = COLOR_ACCENT
            end
        elseif not pnamemode then
            -- Target by touch mode
            if lplr.Character and lplr.Character:FindFirstChildOfClass("Humanoid") and lplr.Character:FindFirstChildOfClass("Humanoid").RootPart then
                StopPlay.Text = "Waiting for Humanoid"
                wfc = true
                touched = lplr.Character:FindFirstChildOfClass("Humanoid").RootPart.Touched:Connect(function(part)
                    if part and not part:IsDescendantOf(lplr.Character) then
                        local hitPlayer = game.Players:GetPlayerFromCharacter(part.Parent)
                        if hitPlayer and hitPlayer ~= lplr then
                            target = hitPlayer.Character
                            wfc = false
                            if lplr.Character and lplr.Character:FindFirstChild("Humanoid") then
                                lplr.Character:FindFirstChild("Humanoid").PlatformStand = true
                            end
                            StopPlay.Text = "Stop"
                            if touched then touched:Disconnect() touched = nil end
                        end
                    end
                end)
            end
        end
    elseif target then
        -- Stop mode
        if lplr.Character and lplr.Character:FindFirstChild("Humanoid") then
            lplr.Character:FindFirstChild("Humanoid"):ChangeState(Enum.HumanoidStateType.GettingUp)
        end
        StopPlay.Text = "Start"
        target = nil
    elseif wfc then
        -- Cancel waiting mode
        wfc = false
        if touched then touched:Disconnect() touched = nil end
        StopPlay.Text = "Start"
    end
end)

-- Fixed speed logic: make higher numbers = faster
local rev = false
local eft = 0
RunService.PreSimulation:Connect(function(dt)
    -- Interpret curspeed as multiplier: larger => faster oscillation
    local speedFactor = math.clamp(curspeed, 0.05, 100)

    if rev then
        eft = eft - (dt * speedFactor)
    else
        eft = eft + (dt * speedFactor)
    end

    if eft >= 1 then
        eft = 1
        rev = true
    elseif eft <= 0 then
        eft = 0
        rev = false
    end

    local count = eft -- ranges 0..1

    if target and target:FindFirstChild("Humanoid") and target.Humanoid.Health > 0 then
        local targetRoot = target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("Torso")
        local localRoot = nil
        if lplr.Character then localRoot = lplr.Character:FindFirstChild("HumanoidRootPart") end

        if targetRoot and localRoot then
            localRoot.CFrame = targetRoot.CFrame * CFrame.new(0,0,0.5) * CFrame.Angles(math.rad((-30 * count) + 10),0,0) * CFrame.new(0,0,1 * count)
            -- zero velocities
            if localRoot:IsA("BasePart") then
                localRoot.Velocity = Vector3.new(0,0,0)
                localRoot.RotationalVelocity = Vector3.new(0,0,0)
            end
        end
    elseif target then
        -- Stop if target is dead or missing parts
        if lplr.Character and lplr.Character:FindFirstChild("Humanoid") then
            lplr.Character:FindFirstChild("Humanoid"):ChangeState(Enum.HumanoidStateType.GettingUp)
        end
        StopPlay.Text = "Start"
        target = nil
    end
end)


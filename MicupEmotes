-- Dragging Logic
local dragging = false
local dragStart, startPos

local function updateDrag(input)
	local delta = input.Position - dragStart
	frame.Position = UDim2.new(
		startPos.X.Scale, startPos.X.Offset + delta.X,
		startPos.Y.Scale, startPos.Y.Offset + delta.Y
	)
end

title.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = frame.Position
	end
end)

title.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		updateDrag(input)
	end
end)

-- Minimize Toggle
local minimized = false
minBtn.MouseButton1Click:Connect(function()
	minimized = not minimized
	content.Visible = not minimized
	local goalSize = minimized and UDim2.new(0, 250, 0, 36) or UDim2.new(0, 250, 0, 280)
	TweenService:Create(frame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = goalSize}):Play()
	minBtn.Text = minimized and "+" or "-"
end)

-- Animation Toggle System
local currentTrack = nil
local currentAnimName = nil

local function ToggleAnimation(animName, animId)
	local character = player.Character or player.CharacterAdded:Wait()
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end

	-- stop if same animation clicked
	if currentAnimName == animName and currentTrack then
		currentTrack:Stop(0.3)
		currentTrack = nil
		currentAnimName = nil
		return
	end

	-- stop any previous animation
	if currentTrack then
		currentTrack:Stop(0.3)
	end

	-- load and play new animation
	local anim = Instance.new("Animation")
	anim.AnimationId = animId
	local track = humanoid:LoadAnimation(anim)
	track.Priority = Enum.AnimationPriority.Action
	track:Play()

	currentTrack = track
	currentAnimName = animName
end

-- Create Animation Buttons
for _, data in ipairs(Animations) do
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -10, 0, 34)
	btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	btn.TextColor3 = Color3.new(1, 1, 1)
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 14
	btn.Text = data.Name
	btn.Parent = content

	local corner = Instance.new("UICorner", btn)
	corner.CornerRadius = UDim.new(0, 6)

	btn.MouseEnter:Connect(function()
		btn.BackgroundColor3 = Color3.fromRGB(85, 85, 85)
	end)
	btn.MouseLeave:Connect(function()
		btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	end)

	btn.MouseButton1Click:Connect(function()
		ToggleAnimation(data.Name, data.ID)
	end)
end

